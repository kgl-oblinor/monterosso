{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "monterosso-app",
  "compatibility_date": "2026-06-16",
  // Static SPA (the dashboard). Unknown paths fall back to index.html so the
  // client-side routes (/dashboard, /admin, /login …) resolve. The API lives
  // separately at monterosso-chat.kgl-56a.workers.dev.
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
