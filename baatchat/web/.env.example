# Base URL of the chat backend Worker (the frontend itself is served separately).
# Defaults to this if unset.
VITE_API_BASE=https://monterosso-chat.workers.dev

# Use the in-app mock/fixture layer instead of the live API.
# Defaults to "true" until the chat/auth endpoints ship. Set to "false" to hit VITE_API_BASE.
VITE_USE_MOCKS=true
